# Copy this file to .env and adjust values for your environment.
#
# Loaded by public/index.php via application/config/env.php on every request.
# Docker Compose also uses this file for MySQL container setup and PHP env_file.

# -----------------------------------------------------
# Application
# -----------------------------------------------------
# APP_ENV controls CodeIgniter ENVIRONMENT (development|testing|production)
APP_NAME=Commerce Portal
APP_ENV=development
# APP_URL is used for config base_url (no trailing slash required)
APP_URL=http://localhost:8080

# -----------------------------------------------------
# Database
# -----------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=commerce_portal
DB_USERNAME=app_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# -----------------------------------------------------
# Stripe
# -----------------------------------------------------
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# -----------------------------------------------------
# API Authentication
# -----------------------------------------------------
API_BEARER_TOKEN=your_api_bearer_token

# -----------------------------------------------------
# Mail
# -----------------------------------------------------
MAIL_PROTOCOL=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_username
MAIL_PASS=your_mailtrap_password
MAIL_FROM_EMAIL=noreply@commerce-portal.test
MAIL_FROM_NAME=Commerce Portal
MAIL_ENABLED=true